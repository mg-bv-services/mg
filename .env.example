# ─── SMTP-configuratie voor contactformulier ───
# Vraag deze gegevens op bij je domein-/mailprovider.

SMTP_HOST=smtp.jouwprovider.nl
SMTP_PORT=587
SMTP_USER=info@mg-services.nl
SMTP_PASS=jouw-wachtwoord-hier
# SMTP_SECURE=true alleen bij port 465 (impliciete TLS). Bij 587 (STARTTLS) op false laten.
SMTP_SECURE=false

# ─── E-mailadressen ───
# MAIL_FROM = afzender (moet bij de SMTP_USER mailbox horen).
# MAIL_TO   = waar contactaanvragen heen gaan (mag hetzelfde zijn als MAIL_FROM).
MAIL_FROM=info@mg-services.nl
MAIL_TO=info@mg-services.nl
